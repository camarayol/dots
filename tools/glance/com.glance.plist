<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.glance</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/camaray/.local/bin/glance</string>
    <string>-config</string>
    <string>/Users/camaray/.config/glance/glance.yml</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/camaray</string>

  <key>StandardOutPath</key>
  <string>/Users/camaray/Library/Logs/glance.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/camaray/Library/Logs/glance.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>/Users/camaray</string>
  </dict>
</dict>
</plist>
