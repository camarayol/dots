theme = One Half Dark

# font
font-size = 20
font-family = Courier
font-style = Normal
font-style-bold = Bold
font-style-italic = Italic
font-feature = -calt, -liga, -dlig
font-codepoint-map = U+4E00-U+9FFF=LXGW WenKai Mono GB Screen

# options
maximize = true
window-padding-x = 4,4
window-padding-y = 4,4
resize-overlay = never
window-decoration = true
window-padding-balance = true
background-opacity = 0.95

confirm-close-surface = false

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

macos-icon = custom
macos-custom-icon = /System/Applications/Utilities/Terminal.app/Contents/Resources/Terminal.icns
macos-option-as-alt = true
macos-titlebar-style  = hidden

# keybinds
keybind = clear
keybind = command+q=quit
keybind = command+c=copy_to_clipboard
keybind = command+v=paste_from_clipboard
keybind = command+shift+r=reload_config
keybind = command+==increase_font_size:1
keybind = command+-=decrease_font_size:1


